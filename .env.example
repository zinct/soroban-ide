# ─── GitHub OAuth ────────────────────────────────────────────────
# Get this from GitHub Developer Settings -> OAuth Apps
VITE_GITHUB_CLIENT_ID=

# ─── Backend Configuration ───────────────────────────────────────
# When running in local development, it defaults to /api (proxied by Vite).
# In production (e.g., Vercel), set this to your full backend URL (e.g., https://api.yoursite.com).
VITE_API_BASE=
BACKEND_URL=

VITE_OPENROUTER_API_KEY
